{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/review-manifest.schema.json",
  "title": "Agentflow Review Manifest",
  "type": "object",
  "required": ["schema_version", "review_run_id", "state_dir", "gate_status", "findings", "artifacts"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^(?:0\\.[0-2]\\.[0-9]+|1\\.0\\.[0-9]+)$" },
    "review_run_id": { "type": "string", "pattern": "^RR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$" },
    "state_dir": { "type": "string", "minLength": 1 },
    "policy": { "type": "string" },
    "gate_status": { "enum": ["pass", "warn", "fail"] },
    "active_blocking": { "type": "array", "items": { "type": "string" } },
    "depth_profile": { "enum": ["none", "light", "standard", "spec_quality", "deep"] },
    "amendment_ready": { "type": "boolean" },
    "findings": {
      "type": "object",
      "properties": {
        "counts_by_severity": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "counts_by_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "index": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["finding_id", "severity", "status"],
            "properties": {
              "finding_id": { "type": "string", "minLength": 1 },
              "severity": { "enum": ["critical", "high", "medium", "low"] },
              "status": { "enum": ["open", "accepted", "fixed", "rejected", "superseded"] },
              "steelman_verdict": { "type": "string" },
              "superseded_by": { "type": "string" },
              "fix_commit": { "type": "string" },
              "owning_step": { "type": "string", "minLength": 1 },
              "claim": { "type": "string", "minLength": 1 },
              "location": {
                "type": "object",
                "required": ["path"],
                "properties": {
                  "path": { "type": "string", "minLength": 1 },
                  "line": { "type": "integer", "minimum": 1 },
                  "line_end": { "type": "integer", "minimum": 1 }
                },
                "dependentRequired": { "line_end": ["line"] },
                "additionalProperties": false
              },
              "suggested_fix": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object", "required": ["path"], "properties": { "path": { "type": "string", "minLength": 1 } }, "additionalProperties": true }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "schema_version": { "pattern": "^1\\.0\\.[0-9]+$" } },
        "required": ["schema_version"]
      },
      "then": {
        "required": ["amendment_ready"],
        "properties": {
          "amendment_ready": { "const": true },
          "findings": {
            "propertyNames": {
              "enum": ["counts_by_severity", "counts_by_status", "index"]
            },
            "required": ["counts_by_severity", "counts_by_status", "index"],
            "properties": {
              "index": {
                "items": {
                  "propertyNames": {
                    "enum": [
                      "finding_id",
                      "severity",
                      "status",
                      "steelman_verdict",
                      "superseded_by",
                      "fix_commit",
                      "owning_step",
                      "claim",
                      "location",
                      "suggested_fix"
                    ]
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": { "status": { "enum": ["open", "accepted"] } },
                        "required": ["status"]
                      },
                      "then": { "required": ["owning_step", "claim", "suggested_fix"] }
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "else": {
        "properties": { "amendment_ready": { "const": false } }
      }
    }
  ],
  "additionalProperties": true
}
