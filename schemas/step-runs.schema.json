{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/step-runs.schema.json",
  "title": "Agentflow Step Runs Ledger Entry",
  "type": "object",
  "required": ["schema_version", "event", "step_id", "attempt_id", "recorded_at"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^0\\.[0-5]\\.[0-9]+$" },
    "event": { "enum": ["abandoned", "amendment_started", "blocked", "claimed", "completed", "failed", "in_progress", "lease_renewed", "verified"] },
    "step_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "pattern": "^(WT[a-z0-9]{1,16}-)?A[0-9]+$" },
    "amends_attempt": { "type": "string", "pattern": "^(WT[a-z0-9]{1,16}-)?A[0-9]+$" },
    "reason_code": { "enum": ["review_feedback", "validation_followup", "operator_correction", "other"] },
    "amends_completed_at": { "type": "string" },
    "agent_id": { "type": "string" },
    "lease_expires_at": { "type": ["string", "null"] },
    "reason": { "type": "string" },
    "abandoned_by": { "type": "string" },
    "failed_by": { "type": "string" },
    "superseded_by": { "type": "string", "pattern": "^(WT[a-z0-9]{1,16}-)?A[0-9]+$" },
    "findings": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "finding_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["review_run_id", "finding_id"],
        "properties": {
          "review_run_id": { "type": "string", "pattern": "^RR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$" },
          "finding_id": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": true
      }
    },
    "recorded_at": { "type": "string" }
  },
  "additionalProperties": true
}
