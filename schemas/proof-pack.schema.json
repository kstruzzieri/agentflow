{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/proof-pack.schema.json",
  "title": "Agentflow Proof Pack Metadata",
  "type": "object",
  "required": ["schema_version", "bundle_version", "meta", "generated_from", "files", "checks", "coverage", "core_sha256"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "bundle_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "bundle_type": { "type": "string" },
    "meta": {
      "type": "object",
      "required": ["created_at", "tool_version"],
      "properties": {
        "created_at": { "type": "string" },
        "tool_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "generated_from": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "files": {
      "type": "array",
      "items": { "$ref": "#/$defs/file" }
    },
    "checks": {
      "type": "array",
      "items": { "$ref": "#/$defs/check" }
    },
    "coverage": {
      "type": "object",
      "properties": {
        "requirements": {
          "type": "array",
          "items": { "$ref": "#/$defs/requirementCoverage" }
        },
        "criterion_status_counts": {
          "type": "object",
          "required": ["satisfied", "failed", "missing", "unmapped"],
          "properties": {
            "satisfied": { "type": "integer", "minimum": 0 },
            "failed": { "type": "integer", "minimum": 0 },
            "missing": { "type": "integer", "minimum": 0 },
            "unmapped": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "core_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "workflow_contract": { "$ref": "#/$defs/workflowContractSummary" },
    "capabilities": { "$ref": "#/$defs/capabilities" },
    "stuck": {
      "type": "object",
      "properties": {
        "rules_evaluated": { "type": "integer" },
        "findings": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["rules_evaluated", "findings"],
      "additionalProperties": true
    },
    "execution": { "$ref": "#/$defs/execution" },
    "review": { "$ref": "#/$defs/review" },
    "aggregation": { "$ref": "#/$defs/aggregation" },
    "runtime": {
      "type": "object",
      "required": ["latest_snapshot_id", "runtime_counts", "mcp_server_counts", "mcp_servers"],
      "properties": {
        "latest_snapshot_id": { "type": "string" },
        "runtime_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "mcp_server_counts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "mcp_servers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "status", "declared_tool_count"],
            "properties": {
              "id": { "type": "string" },
              "status": { "enum": ["configured", "ready", "unavailable"] },
              "declared_tool_count": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "file": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
      },
      "additionalProperties": true
    },
    "check": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "status": {
          "enum": ["failed", "not_applicable", "not_run", "passed", "skipped", "warning"]
        },
        "message": { "type": "string" },
        "count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "criterionEvidence": {
      "type": "object",
      "required": ["kind", "status"],
      "properties": {
        "kind": { "enum": ["command", "inspection", "review"] },
        "status": { "enum": ["satisfied", "failed", "missing"] },
        "step_id": { "type": "string" },
        "gate": { "type": "string" },
        "receipt_id": { "type": "string" },
        "evidence_id": { "type": "string" },
        "minimum_depth": { "enum": ["spec_quality", "deep"] },
        "review_run_id": { "type": "string" },
        "plan_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "depth_profile": { "enum": ["spec_quality", "deep"] }
      },
      "additionalProperties": true
    },
    "criterionCoverage": {
      "type": "object",
      "required": ["id", "text", "status", "steps", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "status": { "enum": ["satisfied", "failed", "missing", "unmapped"] },
        "steps": { "type": "array", "items": { "type": "string" } },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterionEvidence" }
        }
      },
      "additionalProperties": true
    },
    "requirementCoverage": {
      "type": "object",
      "required": ["id", "text", "status", "acceptance_criteria"],
      "properties": {
        "id": { "type": "string" },
        "text": { "type": "string" },
        "status": { "enum": ["satisfied", "failed", "missing", "unmapped"] },
        "acceptance_criteria": {
          "type": "array",
          "items": { "$ref": "#/$defs/criterionCoverage" }
        }
      },
      "additionalProperties": true
    },
    "execution": {
      "type": "object",
      "required": [
        "steps_total",
        "steps_completed",
        "attempts",
        "command_receipts",
        "command_receipts_by_provenance",
        "file_receipts",
        "verification_runs",
        "normalized_execution_sha256",
        "unmapped_changed_files",
        "failed_attempts"
      ],
      "properties": {
        "steps_total": { "type": "integer", "minimum": 0 },
        "steps_completed": { "type": "integer", "minimum": 0 },
        "attempts": { "type": "integer", "minimum": 0 },
        "command_receipts": { "type": "integer", "minimum": 0 },
        "command_receipts_by_provenance": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "command_timed_out": { "type": "integer", "minimum": 0 },
        "command_timeout_seconds": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "file_receipts": { "type": "integer", "minimum": 0 },
        "verification_runs": { "type": "integer", "minimum": 0 },
        "normalized_execution_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "unmapped_changed_files": { "type": "array", "items": { "type": "string" } },
        "failed_attempts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "workflowContractSummary": {
      "type": "object",
      "required": [
        "workflow_pack",
        "workflow_profile",
        "selected_by",
        "review_depth",
        "required_capabilities",
        "required_gates",
        "proof_policy"
      ],
      "properties": {
        "workflow_pack": { "type": "string" },
        "workflow_profile": { "type": "string" },
        "selected_by": { "type": "string" },
        "review_depth": { "type": "string" },
        "required_capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "required_gates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proof_policy": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "capabilities": {
      "type": "object",
      "required": ["required", "recorded", "waived", "missing"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "recorded": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "waived": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "missing": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "review": {
      "type": "object",
      "properties": {
        "review_runs": { "type": "array", "items": { "$ref": "#/$defs/reviewRunSummary" } },
        "latest_review_run_id": { "type": ["string", "null"] },
        "correlations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "unresolved_finding_refs": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "policy": { "$ref": "#/$defs/reviewPolicy" }
      },
      "additionalProperties": true
    },
    "reviewFindingLocation": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 }
      },
      "dependentRequired": { "line_end": ["line"] },
      "additionalProperties": false
    },
    "reviewFinding": {
      "type": "object",
      "required": ["finding_id", "severity", "status"],
      "properties": {
        "finding_id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "status": { "enum": ["open", "accepted", "fixed", "rejected", "superseded"] },
        "steelman_verdict": { "type": "string" },
        "superseded_by": { "type": "string" },
        "fix_commit": { "type": "string" },
        "owning_step": { "type": "string", "minLength": 1 },
        "claim": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/reviewFindingLocation" },
        "suggested_fix": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "reviewFindingsProjection": {
      "type": "object",
      "required": ["counts_by_severity", "counts_by_status", "index"],
      "properties": {
        "counts_by_severity": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "counts_by_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "index": { "type": "array", "items": { "$ref": "#/$defs/reviewFinding" } }
      },
      "additionalProperties": true
    },
    "reviewRunSummary": {
      "type": "object",
      "properties": {
        "review_run_id": { "type": "string" },
        "plan_sha256": { "type": ["string", "null"] },
        "gate_status": { "enum": ["pass", "warn", "fail"] },
        "active_blocking": { "type": "array", "items": { "type": "string" } },
        "counts_by_severity": { "type": "object" },
        "counts_by_status": { "type": "object" },
        "amendment_ready": { "type": "boolean" },
        "findings": { "type": "object", "additionalProperties": true },
        "artifacts": { "type": "array", "items": { "type": "object" } },
        "depth_profile": { "enum": ["none", "light", "standard", "spec_quality", "deep"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "amendment_ready": { "const": true } },
            "required": ["amendment_ready"]
          },
          "then": {
            "required": ["findings"],
            "properties": {
              "findings": {
                "$ref": "#/$defs/reviewFindingsProjection",
                "propertyNames": { "enum": ["counts_by_severity", "counts_by_status", "index"] },
                "properties": {
                  "index": {
                    "items": {
                      "propertyNames": {
                        "enum": ["finding_id", "severity", "status", "steelman_verdict", "superseded_by", "fix_commit", "owning_step", "claim", "location", "suggested_fix"]
                      },
                      "allOf": [
                        {
                          "if": {
                            "properties": { "status": { "enum": ["open", "accepted"] } },
                            "required": ["status"]
                          },
                          "then": { "required": ["owning_step", "claim", "suggested_fix"] }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      ],
      "additionalProperties": true
    },
    "reviewPolicy": {
      "type": "object",
      "required": [
        "review_gate_effective",
        "proof_strict_effective",
        "require_review_run",
        "verification_semantics"
      ],
      "properties": {
        "review_gate_effective": { "enum": ["ignore", "warn", "block"] },
        "proof_strict_effective": { "type": "boolean" },
        "require_review_run": { "type": "boolean" },
        "verification_semantics": { "enum": ["ratchet-v1"] }
      },
      "additionalProperties": true
    },
    "aggregation": {
      "type": "object",
      "required": ["mode", "source_count", "sources", "schema_version"],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^0\\.[0-1]\\.[0-9]+$" },
        "mode": { "enum": ["cross_worktree"] },
        "source_count": { "type": "integer", "minimum": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["source_id", "root_label", "base_commit", "head_commit", "namespaced_prefix"],
            "properties": {
              "source_id": { "type": "string", "pattern": "^[a-z0-9]{1,16}$" },
              "root_label": { "type": "string" },
              "base_commit": { "type": ["string", "null"] },
              "head_commit": { "type": ["string", "null"] },
              "namespaced_prefix": { "type": "string", "pattern": "^WT[a-z0-9]{1,16}-$" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
