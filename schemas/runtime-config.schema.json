{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/runtime-config.schema.json",
  "title": "Agentflow Runtime Config",
  "type": "object",
  "required": ["schema_version", "runtimes", "routes"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^0\\.[0-3]\\.[0-9]+$" },
    "default_runtime": { "type": "string", "minLength": 1 },
    "runtimes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/runtime" }
    },
    "routes": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/route" }
    },
    "mcp_servers": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/mcp_server" }
    }
  },
  "$defs": {
    "mcp_transport": { "enum": ["http", "sse", "stdio"] },
    "mcp_readiness_check": { "enum": ["command_exists", "command_spawn", "http_status", "none"] },
    "mcp_server": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "transport": { "$ref": "#/$defs/mcp_transport" },
        "declared_tools": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "readiness": {
          "type": "object",
          "properties": {
            "check": { "$ref": "#/$defs/mcp_readiness_check" },
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "spawn": {
              "type": "object",
              "properties": { "grace_seconds": { "type": "number", "minimum": 0 } },
              "additionalProperties": true
            },
            "url": { "type": "string" },
            "timeout_seconds": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "adapter": {
      "enum": ["claude", "codex", "custom", "go-llm", "openai-compatible"]
    },
    "route_policy": {
      "enum": ["manual_only", "prefer_local", "prefer_low_cost", "prefer_quality", "prefer_speed"]
    },
    "readiness_check": {
      "enum": ["command_exists", "command_spawn", "http", "http_status", "none"]
    },
    "runtime": {
      "type": "object",
      "required": ["adapter", "enabled"],
      "properties": {
        "adapter": { "$ref": "#/$defs/adapter" },
        "enabled": { "type": "boolean" },
        "capabilities": {
          "type": "object",
          "properties": {
            "declared": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "required": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          },
          "additionalProperties": true
        },
        "readiness": {
          "type": "object",
          "properties": {
            "check": { "$ref": "#/$defs/readiness_check" },
            "command": { "type": "string" },
            "args": { "type": "array", "items": { "type": "string" } },
            "http": {
              "type": "object",
              "properties": {
                "models_url": { "type": "string" },
                "timeout_seconds": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": true
            },
            "spawn": {
              "type": "object",
              "properties": {
                "grace_seconds": { "type": "number", "minimum": 0 }
              },
              "additionalProperties": true
            },
            "url": { "type": "string" },
            "timeout_seconds": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": true
        },
        "mcp": { "type": "object", "additionalProperties": true },
        "openai_compat": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "route": {
      "type": "object",
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "fallbacks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "policy": { "$ref": "#/$defs/route_policy" },
        "requires": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "allow_degraded": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
