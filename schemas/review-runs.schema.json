{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/review-runs.schema.json",
  "title": "Agentflow Review Run Ledger Entry",
  "type": "object",
  "required": ["schema_version", "review_run_id", "recorded_at", "state_dir", "manifest_path", "manifest_sha256", "gate_status", "artifacts"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "review_run_id": { "type": "string", "pattern": "^RR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$" },
    "recorded_at": { "type": "string" },
    "state_dir": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string" },
    "manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "plan_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy": { "type": ["string", "null"] },
    "gate_status": { "enum": ["pass", "warn", "fail"] },
    "active_blocking": { "type": "array", "items": { "type": "string" } },
    "depth_profile": { "enum": ["none", "light", "standard", "spec_quality", "deep"] },
    "amendment_ready": { "type": "boolean" },
    "findings": { "type": "object", "additionalProperties": true },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "findingLocation": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 }
      },
      "dependentRequired": { "line_end": ["line"] },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": ["finding_id", "severity", "status"],
      "properties": {
        "finding_id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "status": { "enum": ["open", "accepted", "fixed", "rejected", "superseded"] },
        "steelman_verdict": { "type": "string" },
        "superseded_by": { "type": "string" },
        "fix_commit": { "type": "string" },
        "owning_step": { "type": "string", "minLength": 1 },
        "claim": { "type": "string", "minLength": 1 },
        "location": { "$ref": "#/$defs/findingLocation" },
        "suggested_fix": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "findingsProjection": {
      "type": "object",
      "required": ["counts_by_severity", "counts_by_status", "index"],
      "properties": {
        "counts_by_severity": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "counts_by_status": { "type": "object", "additionalProperties": { "type": "integer", "minimum": 0 } },
        "index": { "type": "array", "items": { "$ref": "#/$defs/finding" } }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "amendment_ready": { "const": true } },
        "required": ["amendment_ready"]
      },
      "then": {
        "required": ["findings"],
        "properties": {
          "findings": {
            "$ref": "#/$defs/findingsProjection",
            "propertyNames": { "enum": ["counts_by_severity", "counts_by_status", "index"] },
            "properties": {
              "index": {
                "items": {
                  "propertyNames": {
                    "enum": ["finding_id", "severity", "status", "steelman_verdict", "superseded_by", "fix_commit", "owning_step", "claim", "location", "suggested_fix"]
                  },
                  "allOf": [
                    {
                      "if": {
                        "properties": { "status": { "enum": ["open", "accepted"] } },
                        "required": ["status"]
                      },
                      "then": { "required": ["owning_step", "claim", "suggested_fix"] }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
