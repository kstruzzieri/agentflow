{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentflow.dev/schemas/review-runs.schema.json",
  "title": "Agentflow Review Run Ledger Entry",
  "type": "object",
  "required": ["schema_version", "review_run_id", "recorded_at", "state_dir", "manifest_path", "manifest_sha256", "gate_status", "artifacts"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^0\\.[0-9]+\\.[0-9]+$" },
    "review_run_id": { "type": "string", "pattern": "^RR-[0-9]{8}T[0-9]{6}Z-[0-9a-f]{8}$" },
    "recorded_at": { "type": "string" },
    "state_dir": { "type": "string", "minLength": 1 },
    "manifest_path": { "type": "string" },
    "manifest_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "plan_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "policy": { "type": ["string", "null"] },
    "gate_status": { "enum": ["pass", "warn", "fail"] },
    "active_blocking": { "type": "array", "items": { "type": "string" } },
    "depth_profile": { "enum": ["none", "light", "standard", "spec_quality", "deep"] },
    "findings": { "type": "object", "additionalProperties": true },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
